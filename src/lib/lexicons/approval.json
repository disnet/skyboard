{
  "lexicon": 1,
  "id": "dev.skyboard.approval",
  "defs": {
    "main": {
      "type": "record",
      "description": "An approval for content (task, comment, placement, taskOp). Scope is determined by who creates it (the approval author's DID).",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["targetUri", "createdAt"],
        "properties": {
          "targetUri": {
            "type": "string",
            "format": "at-uri",
            "description": "AT URI of the content being approved"
          },
          "createdAt": {
            "type": "string",
            "format": "datetime",
            "description": "When the approval was created"
          }
        }
      }
    }
  }
}
