{
  "lexicon": 1,
  "id": "dev.skyboard.task",
  "defs": {
    "main": {
      "type": "record",
      "description": "A standalone task. May be placed on boards via placement records.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["title", "createdAt"],
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 1024,
            "description": "Title of the task"
          },
          "description": {
            "type": "string",
            "maxLength": 10240,
            "description": "Optional description of the task"
          },
          "status": {
            "type": "string",
            "enum": ["open", "closed"],
            "description": "Task-level status"
          },
          "open": {
            "type": "boolean",
            "description": "Permission flag: if true, anyone can edit this task"
          },
          "labelIds": {
            "type": "array",
            "maxLength": 50,
            "items": { "type": "string" },
            "description": "IDs of labels assigned to this task"
          },
          "forkedFrom": {
            "type": "string",
            "format": "at-uri",
            "description": "AT URI of the original task this was forked from"
          },
          "columnId": {
            "type": "string",
            "description": "Legacy: ID of the column this task belongs to"
          },
          "boardUri": {
            "type": "string",
            "format": "at-uri",
            "description": "Legacy: AT URI of the parent board. Use placements instead."
          },
          "position": {
            "type": "string",
            "maxLength": 256,
            "description": "Legacy: Fractional index position. Use placements instead."
          },
          "order": {
            "type": "integer",
            "minimum": 0,
            "description": "Deprecated. Sort order within the column"
          },
          "createdAt": {
            "type": "string",
            "format": "datetime",
            "description": "When the task was created"
          },
          "updatedAt": {
            "type": "string",
            "format": "datetime",
            "description": "When the task was last updated"
          }
        }
      }
    }
  }
}
